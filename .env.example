# .env.example — kopieer dit naar .env.local en vul jouw waarden in.
# .env.local staat in .gitignore en wordt NOOIT gecommit.

# --- Firebase (haal op uit Firebase Console → Project Settings) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- GitHub Personal Access Token ---
# Maak aan op: https://github.com/settings/tokens
# Benodigde scopes: repo (voor privé-repos) of public_repo (voor publieke repos)
# Fine-grained token: Actions → Read-only is voldoende
VITE_GITHUB_TOKEN=

# --- Google PageSpeed Insights API Key ---
# Maak aan op: https://console.cloud.google.com/apis/credentials
# Activeer: "PageSpeed Insights API" in de API Library
# Zonder key werkt PSI ook, maar met rate limiting (400 req/dag per IP)
VITE_PAGESPEED_API_KEY=
