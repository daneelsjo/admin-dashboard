rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Alle collecties (sites, domains, ...): alleen toegankelijk als je ingelogd bent.
    // Het dashboard is al beveiligd via Firebase Auth — enkel jij kan inloggen.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
